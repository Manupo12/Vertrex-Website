<!DOCTYPE html>
<html lang="{{lang}}">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{document.title}}</title>
    <style>{{{designTokensCss}}}</style>
  </head>
  <body>
    <article class="document-shell">
      <header class="hero">
        <div class="hero__brand">
          <img class="brand-mark" src="{{logoDataUrl}}" alt="Vertrex" />
          <div class="brand-copy">
            <span class="brand-name">{{branding.name}}</span>
            <span class="brand-tagline">{{branding.tagline}}</span>
            <p class="brand-subtitle">{{template.description}}</p>
          </div>
        </div>
        <div class="hero__meta">
          <div class="meta-row"><span>Fecha</span><span>{{document.date}}</span></div>
          <div class="meta-row"><span>Código</span><span>{{document.code}}</span></div>
          <div class="meta-row"><span>Ciudad</span><span>{{document.city}}</span></div>
          <div class="meta-row"><span>Proyecto</span><span>{{document.client.name}}</span></div>
        </div>
      </header>

      <section class="document-body">
        <div class="document-header">
          <span class="document-kicker">Statement of Work</span>
          <h1 class="document-title">{{document.title}}</h1>
          <p class="document-subtitle">{{document.subject}}</p>
          <div class="chip-row">
            <span class="chip chip--accent">{{template.category}}</span>
            <span class="chip">Alcance aprobado</span>
            <span class="chip">Single Source of Truth</span>
          </div>
        </div>

        <div class="dual-grid">
          <section class="card card--accent">
            <p class="card__eyebrow">Agencia / operador</p>
            <h2 class="card__title">Vertrex</h2>
            <div class="card__body">
              <p>{{document.intro}}</p>
            </div>
          </section>
          <section class="card">
            <p class="card__eyebrow">Cliente / frente</p>
            <h2 class="card__title">{{document.client.name}}</h2>
            <ul class="info-list">
              <li><span class="info-label">Contacto</span><span class="info-value">{{document.client.email}} · {{document.client.phone}}</span></li>
              <li><span class="info-label">Ubicación</span><span class="info-value">{{document.client.address}}</span></li>
              <li><span class="info-label">Código base</span><span class="info-value">{{document.code}}</span></li>
            </ul>
          </section>
        </div>

        <section class="section">
          <div class="section__header">
            <p class="section__eyebrow">Objetivo</p>
            <h2 class="section__title">Qué cubre exactamente este SOW</h2>
            <p class="section__description">{{document.summary}}</p>
          </div>
          <ul class="bullet-list">
            {{#each document.scopeItems}}
              <li>
                <span class="bullet-index">{{index}}</span>
                <p>{{value}}</p>
              </li>
            {{/each}}
          </ul>
        </section>

        <section class="section">
          <div class="section__header">
            <p class="section__eyebrow">Dependencias</p>
            <h2 class="section__title">Qué necesita Vertrex del cliente</h2>
            <p class="section__description">Estas variables afectan plazo, calidad y continuidad del roadmap acordado.</p>
          </div>
          <ul class="clause-list">
            {{#each document.requirementItems}}
              <li>
                <span class="clause-index">{{index}}</span>
                <p>{{value}}</p>
              </li>
            {{/each}}
          </ul>
        </section>

        <section class="section">
          <div class="section__header">
            <p class="section__eyebrow">Criterio de decisión</p>
            <h2 class="section__title">Regla de interpretación del alcance</h2>
            <p class="section__description">Todo entregable o funcionalidad no descrito explícitamente en este documento debe considerarse fuera de alcance y requerirá aprobación o documento complementario.</p>
          </div>
          <section class="card card--accent">
            <div class="card__body">
              <p>{{document.closing}}</p>
            </div>
          </section>
        </section>

        <div class="signature-panel">
          <div class="stack">
            <section class="card">
              <p class="card__eyebrow">Emitido por</p>
              <h2 class="card__title">{{document.signatory.name}}</h2>
              <div class="card__body">
                <p>{{document.signatory.role}} · {{document.signatory.documentId}}</p>
              </div>
            </section>
          </div>
          <div class="signature-block">
            <img class="signature-image" src="{{signatureDataUrl}}" alt="Firma Vertrex" />
            <div class="signature-line"></div>
            <p class="signature-name">{{document.signatory.name}}</p>
            <p class="signature-role">{{document.signatory.role}}</p>
            <p class="signature-meta">{{branding.email}} · {{branding.phone}}</p>
          </div>
        </div>
      </section>

      <footer class="footer">
        <div class="footer__accent"></div>
        <div class="footer__body">
          <div class="footer__brand">
            <span class="footer__brand-name">{{branding.name}}</span>
            <p class="footer__copy">SOW operativo ligado al generador documental, CRM y seguimiento de entregables.</p>
          </div>
          <p class="footer__links">{{branding.email}}<br />{{branding.phone}}<br />{{branding.instagram}}</p>
        </div>
      </footer>
    </article>
  </body>
</html>
