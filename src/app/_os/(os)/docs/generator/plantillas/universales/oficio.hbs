<!DOCTYPE html>
<html lang="{{lang}}">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{document.title}}</title>
    <style>{{{designTokensCss}}}</style>
  </head>
  <body>
    <article class="document-shell">
      <header class="hero">
        <div class="hero__brand">
          <img class="brand-mark" src="{{logoDataUrl}}" alt="Vertrex" />
          <div class="brand-copy">
            <span class="brand-name">{{branding.name}}</span>
            <span class="brand-tagline">{{branding.tagline}}</span>
            <p class="brand-subtitle">{{template.description}}</p>
          </div>
        </div>
        <div class="hero__meta">
          <div class="meta-row"><span>Fecha</span><span>{{document.date}}</span></div>
          <div class="meta-row"><span>Código</span><span>{{document.code}}</span></div>
          <div class="meta-row"><span>Ciudad</span><span>{{document.city}}</span></div>
          <div class="meta-row"><span>Tipo</span><span>{{template.label}}</span></div>
        </div>
      </header>

      <section class="document-body">
        <div class="document-header">
          <span class="document-kicker">Documento Comercial</span>
          <h1 class="document-title">{{document.title}}</h1>
          <p class="document-subtitle">{{document.subject}}</p>
          <div class="chip-row">
            <span class="chip chip--accent">{{template.category}}</span>
            <span class="chip">{{document.client.name}}</span>
            <span class="chip">Vertrex OS · Generación Inteligente</span>
          </div>
        </div>

        <div class="data-grid">
          <section class="card card--accent">
            <p class="card__eyebrow">Destinatario</p>
            <h2 class="card__title">{{document.client.name}}</h2>
            <ul class="info-list">
              <li>
                <span class="info-label">Identificación</span>
                <span class="info-value">{{document.client.nit}}</span>
              </li>
              <li>
                <span class="info-label">Dirección</span>
                <span class="info-value">{{document.client.address}}</span>
              </li>
              <li>
                <span class="info-label">Contacto</span>
                <span class="info-value">{{document.client.email}} · {{document.client.phone}}</span>
              </li>
            </ul>
          </section>
          <section class="card">
            <p class="card__eyebrow">Propósito</p>
            <h2 class="card__title">Presentación y alineación</h2>
            <div class="card__body">
              <p>{{document.intro}}</p>
            </div>
          </section>
        </div>

        <section class="section">
          <div class="section__header">
            <p class="section__eyebrow">Resumen ejecutivo</p>
            <h2 class="section__title">Por qué existe este oficio</h2>
            <p class="section__description">{{document.summary}}</p>
          </div>
          <div class="summary-grid">
            <section class="card">
              <p class="metric-label">Cliente</p>
              <p class="metric-value">{{document.client.name}}</p>
            </section>
            <section class="card">
              <p class="metric-label">Código</p>
              <p class="metric-value">{{document.code}}</p>
            </section>
            <section class="card card--accent">
              <p class="metric-label">Enfoque</p>
              <p class="metric-value">{{template.category}}</p>
            </section>
          </div>
        </section>

        <section class="section">
          <div class="section__header">
            <p class="section__eyebrow">Alcance visible</p>
            <h2 class="section__title">Frentes que quedan sobre la mesa</h2>
          </div>
          <ul class="bullet-list">
            {{#each document.scopeItems}}
              <li>
                <span class="bullet-index">{{index}}</span>
                <p>{{value}}</p>
              </li>
            {{/each}}
          </ul>
        </section>

        <section class="section">
          <div class="section__header">
            <p class="section__eyebrow">Dependencias del cliente</p>
            <h2 class="section__title">Validaciones para continuar sin fricción</h2>
          </div>
          <ul class="bullet-list">
            {{#each document.requirementItems}}
              <li>
                <span class="bullet-index">{{index}}</span>
                <p>{{value}}</p>
              </li>
            {{/each}}
          </ul>
        </section>

        <section class="section">
          <div class="section__header">
            <p class="section__eyebrow">Cierre</p>
            <h2 class="section__title">Siguiente movimiento recomendado</h2>
            <p class="section__description">{{document.closing}}</p>
          </div>
        </section>

        <div class="signature-panel">
          <div class="stack">
            <p class="amount-words">Generado desde Vertrex OS como single source of truth documental.</p>
          </div>
          <div class="signature-block">
            <img class="signature-image" src="{{signatureDataUrl}}" alt="Firma Vertrex" />
            <div class="signature-line"></div>
            <p class="signature-name">{{document.signatory.name}}</p>
            <p class="signature-role">{{document.signatory.role}}</p>
            <p class="signature-meta">Documento: {{document.signatory.documentId}} · Tel: {{document.signatory.phone}}</p>
          </div>
        </div>
      </section>

      <footer class="footer">
        <div class="footer__accent"></div>
        <div class="footer__body">
          <div class="footer__brand">
            <span class="footer__brand-name">{{branding.name}}</span>
            <p class="footer__copy">{{branding.location}}</p>
          </div>
          <p class="footer__links">{{branding.email}}<br />{{branding.phone}}<br />{{branding.instagram}}</p>
        </div>
      </footer>
    </article>
  </body>
</html>
