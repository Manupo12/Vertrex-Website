<!DOCTYPE html>
<html lang="{{lang}}">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{document.title}}</title>
    <style>{{{designTokensCss}}}</style>
  </head>
  <body>
    <article class="document-shell">
      <header class="hero">
        <div class="hero__brand">
          <img class="brand-mark" src="{{logoDataUrl}}" alt="Vertrex" />
          <div class="brand-copy">
            <span class="brand-name">{{branding.name}}</span>
            <span class="brand-tagline">{{branding.tagline}}</span>
            <p class="brand-subtitle">{{template.description}}</p>
          </div>
        </div>
        <div class="hero__meta">
          <div class="meta-row"><span>Fecha</span><span>{{document.date}}</span></div>
          <div class="meta-row"><span>Código</span><span>{{document.code}}</span></div>
          <div class="meta-row"><span>Ciudad</span><span>{{document.city}}</span></div>
          <div class="meta-row"><span>Total</span><span>{{document.totalAmountFormatted}}</span></div>
        </div>
      </header>

      <section class="document-body">
        <div class="document-header">
          <span class="document-kicker">Documento Financiero</span>
          <h1 class="document-title">{{document.title}}</h1>
          <p class="document-subtitle">{{document.subject}}</p>
          <div class="chip-row">
            <span class="chip chip--accent">{{template.category}}</span>
            <span class="chip">Cobro emitido a {{document.client.name}}</span>
          </div>
        </div>

        <div class="dual-grid">
          <section class="card card--accent">
            <p class="card__eyebrow">Emisor</p>
            <h2 class="card__title">Vertrex</h2>
            <ul class="info-list">
              <li><span class="info-label">Representante</span><span class="info-value">{{document.signatory.name}}</span></li>
              <li><span class="info-label">Correo</span><span class="info-value">{{branding.email}}</span></li>
              <li><span class="info-label">Teléfono</span><span class="info-value">{{branding.phone}}</span></li>
            </ul>
          </section>
          <section class="card">
            <p class="card__eyebrow">Deudor</p>
            <h2 class="card__title">{{document.client.name}}</h2>
            <ul class="info-list">
              <li><span class="info-label">Identificación</span><span class="info-value">{{document.client.nit}}</span></li>
              <li><span class="info-label">Dirección</span><span class="info-value">{{document.client.address}}</span></li>
              <li><span class="info-label">Contacto</span><span class="info-value">{{document.client.email}} · {{document.client.phone}}</span></li>
            </ul>
          </section>
        </div>

        <section class="section">
          <div class="section__header">
            <p class="section__eyebrow">Conceptos facturables</p>
            <h2 class="section__title">Detalle del cobro</h2>
            <p class="section__description">{{document.summary}}</p>
          </div>

          <table class="finance-table">
            <thead>
              <tr>
                <th>Concepto</th>
                <th>Valor</th>
              </tr>
            </thead>
            <tbody>
              {{#each document.lineItems}}
                <tr>
                  <td>
                    <strong>{{label}}</strong><br />
                    <span>{{description}}</span>
                  </td>
                  <td>{{amount}}</td>
                </tr>
              {{/each}}
            </tbody>
            <tfoot>
              <tr>
                <td>Total</td>
                <td>{{document.totalAmountFormatted}}</td>
              </tr>
            </tfoot>
          </table>

          <p class="amount-words">SON: {{document.totalAmountInWords}}</p>
        </section>

        <section class="section">
          <div class="section__header">
            <p class="section__eyebrow">Condiciones de pago</p>
            <h2 class="section__title">Validaciones para cierre financiero</h2>
            <p class="section__description">{{document.intro}}</p>
          </div>
          <ul class="bullet-list">
            {{#each document.requirementItems}}
              <li>
                <span class="bullet-index">{{index}}</span>
                <p>{{value}}</p>
              </li>
            {{/each}}
          </ul>
        </section>

        <section class="section">
          <div class="section__header">
            <p class="section__eyebrow">Cierre</p>
            <h2 class="section__title">Nota operativa</h2>
            <p class="section__description">{{document.closing}}</p>
          </div>
        </section>

        <div class="signature-panel">
          <div class="stack">
            <section class="card card--accent">
              <p class="card__eyebrow">Observación</p>
              <div class="card__body">
                <p>Este documento fue generado desde Vertrex OS y subido al vault documental para trazabilidad financiera y auditoría.</p>
              </div>
            </section>
          </div>
          <div class="signature-block">
            <img class="signature-image" src="{{signatureDataUrl}}" alt="Firma Vertrex" />
            <div class="signature-line"></div>
            <p class="signature-name">{{document.signatory.name}}</p>
            <p class="signature-role">{{document.signatory.role}}</p>
            <p class="signature-meta">Documento: {{document.signatory.documentId}} · Tel: {{document.signatory.phone}}</p>
          </div>
        </div>
      </section>

      <footer class="footer">
        <div class="footer__accent"></div>
        <div class="footer__body">
          <div class="footer__brand">
            <span class="footer__brand-name">{{branding.name}}</span>
            <p class="footer__copy">Cuenta de cobro alineada al sistema financiero interno y al portal del cliente.</p>
          </div>
          <p class="footer__links">{{branding.email}}<br />{{branding.phone}}<br />{{branding.location}}</p>
        </div>
      </footer>
    </article>
  </body>
</html>
