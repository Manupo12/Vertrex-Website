<!DOCTYPE html>
<html lang="{{lang}}">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{document.title}}</title>
    <style>{{{designTokensCss}}}</style>
  </head>
  <body>
    <article class="document-shell">
      <header class="hero">
        <div class="hero__brand">
          <img class="brand-mark" src="{{logoDataUrl}}" alt="Vertrex" />
          <div class="brand-copy">
            <span class="brand-name">{{branding.name}}</span>
            <span class="brand-tagline">{{branding.tagline}}</span>
            <p class="brand-subtitle">{{template.description}}</p>
          </div>
        </div>
        <div class="hero__meta">
          <div class="meta-row"><span>Fecha</span><span>{{document.date}}</span></div>
          <div class="meta-row"><span>Código</span><span>{{document.code}}</span></div>
          <div class="meta-row"><span>Ciudad</span><span>{{document.city}}</span></div>
          <div class="meta-row"><span>Tipo</span><span>{{template.label}}</span></div>
        </div>
      </header>

      <section class="document-body">
        <div class="document-header">
          <span class="document-kicker">Marco Legal</span>
          <h1 class="document-title">{{document.title}}</h1>
          <p class="document-subtitle">{{document.subject}}</p>
          <div class="chip-row">
            <span class="chip chip--accent">{{template.category}}</span>
            <span class="chip">Acuerdo Vertrex x {{document.client.name}}</span>
          </div>
        </div>

        <div class="dual-grid">
          <section class="card card--accent">
            <p class="card__eyebrow">Contratista</p>
            <h2 class="card__title">Vertrex</h2>
            <ul class="info-list">
              <li><span class="info-label">Representante</span><span class="info-value">{{document.signatory.name}}</span></li>
              <li><span class="info-label">Cargo</span><span class="info-value">{{document.signatory.role}}</span></li>
              <li><span class="info-label">Contacto</span><span class="info-value">{{branding.email}} · {{branding.phone}}</span></li>
            </ul>
          </section>
          <section class="card">
            <p class="card__eyebrow">Contratante</p>
            <h2 class="card__title">{{document.client.name}}</h2>
            <ul class="info-list">
              <li><span class="info-label">Identificación</span><span class="info-value">{{document.client.nit}}</span></li>
              <li><span class="info-label">Dirección</span><span class="info-value">{{document.client.address}}</span></li>
              <li><span class="info-label">Contacto</span><span class="info-value">{{document.client.email}} · {{document.client.phone}}</span></li>
            </ul>
          </section>
        </div>

        <section class="section">
          <div class="section__header">
            <p class="section__eyebrow">Objeto</p>
            <h2 class="section__title">Alcance contractual del servicio</h2>
            <p class="section__description">{{document.intro}}</p>
          </div>
          <ul class="clause-list">
            {{#each document.scopeItems}}
              <li>
                <span class="clause-index">{{index}}</span>
                <p>{{value}}</p>
              </li>
            {{/each}}
          </ul>
        </section>

        <section class="section">
          <div class="section__header">
            <p class="section__eyebrow">Condiciones</p>
            <h2 class="section__title">Obligaciones y dependencias críticas</h2>
            <p class="section__description">{{document.summary}}</p>
          </div>
          <ul class="clause-list">
            {{#each document.requirementItems}}
              <li>
                <span class="clause-index">{{index}}</span>
                <p>{{value}}</p>
              </li>
            {{/each}}
          </ul>
        </section>

        <section class="section">
          <div class="section__header">
            <p class="section__eyebrow">Vigencia operativa</p>
            <h2 class="section__title">Criterio de continuidad y ejecución</h2>
            <p class="section__description">{{document.closing}}</p>
          </div>
          <div class="summary-grid">
            <section class="card">
              <p class="metric-label">Modelo</p>
              <p class="metric-value">Servicios</p>
            </section>
            <section class="card card--accent">
              <p class="metric-label">Relación</p>
              <p class="metric-value">B2B</p>
            </section>
            <section class="card">
              <p class="metric-label">Fuente</p>
              <p class="metric-value">Vertrex OS</p>
            </section>
          </div>
        </section>

        <div class="signature-panel">
          <div class="signature-block">
            <img class="signature-image" src="{{signatureDataUrl}}" alt="Firma Vertrex" />
            <div class="signature-line"></div>
            <p class="signature-name">{{document.signatory.name}}</p>
            <p class="signature-role">{{document.signatory.role}}</p>
            <p class="signature-meta">Documento: {{document.signatory.documentId}} · {{branding.location}}</p>
          </div>
          <div class="signature-block">
            <div class="signature-line"></div>
            <p class="signature-name">{{document.client.name}}</p>
            <p class="signature-role">Contratante</p>
            <p class="signature-meta">{{document.client.nit}} · {{document.client.email}}</p>
          </div>
        </div>
      </section>

      <footer class="footer">
        <div class="footer__accent"></div>
        <div class="footer__body">
          <div class="footer__brand">
            <span class="footer__brand-name">{{branding.name}}</span>
            <p class="footer__copy">Contrato emitido desde el sistema central de operación y compliance.</p>
          </div>
          <p class="footer__links">{{branding.email}}<br />{{branding.phone}}<br />{{branding.location}}</p>
        </div>
      </footer>
    </article>
  </body>
</html>
